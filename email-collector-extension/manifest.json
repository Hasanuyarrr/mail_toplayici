{
  "manifest_version": 3,
  "name": "Mail Toplayıcı",
  "version": "1.1.0",
  "description": "Gezindiğiniz sayfalardaki e-posta adreslerini toplar ve TXT olarak dışa aktarır.",
  "permissions": ["storage", "downloads"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Mail Toplayıcı"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
